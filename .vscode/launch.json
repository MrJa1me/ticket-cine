  "compounds": [
    {
      "name": "Debug All Services",
      "configurations": [
        "Debug Eureka",
        "Debug API Gateway",
        "Debug ms-artistas",
        "Debug ms-boletos",
        "Debug ms-catalogo",
        "Debug ms-compras",
