{
  // Configuramos estos puertos en el rango de los 10 mil para crear canales de comunicación exclusivos
  // y aislados dedicados al monitoreo y la depuración (debug) de cada microservicio en tiempo real. 
  // Como las aplicaciones web ya consumen puertos estándar inferiores (como el 8761 para Eureka o 
  // el 9000 para el Gateway), asignarle a cada una un puerto técnico en los 10 mil evita por completo 
  // los conflictos de puertos (el error de puerto ya ocupado); esto garantiza que las herramientas 
  // de desarrollo puedan conectarse a la memoria de Java para analizar errores en vivo sin interrumpir, 
  // saturar ni colapsar el tráfico de red principal del sistema.
  
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug Eureka",
      "request": "launch",
      "cwd": "${workspaceFolder}/eureka",
      "mainClass": "cl.ticketcine.eureka.TicketCineEurekaApplication",
      "projectName": "cl-ticketcine-eureka",
      "vmArgs": "-Dcom.sun.management.jmxremote.port=10761 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false"
    },
    {
      "type": "java",
      "name": "Debug API Gateway",
      "request": "launch",
      "cwd": "${workspaceFolder}/api-gateway",
      "mainClass": "cl.ticketcine.gateway.TicketCineGatewayApplication",
      "projectName": "cl-ticketcine-gateway",
      "vmArgs": "-Dcom.sun.management.jmxremote.port=10900 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false",
      "preLaunchTask": "Wait for Eureka"
    },
    {
      "type": "java",
      "name": "Debug ms-artistas",
      "request": "launch",
      "cwd": "${workspaceFolder}/ms-artistas",
      "mainClass": "cl.ticketcine.artistas.TicketCineArtistasApplication",
