{
  "info": {
    "_postman_id": "ticketcine-gateway-2026",
    "name": "TicketCine API",
    "description": "Colección Postman para **TicketCine** vía API Gateway (`{{gateway_url}}`).\n\n**Arranque:** ejecutar `run-dockers.bat` (gateway :9000, Eureka :8761).\n\n**Credenciales seed** (password `TicketCine@2026`):\n- Administrador: `ana@administrador.cl` o `admin@ticketcine.cl`\n- Organizador: `beatriz@organizador.cl`\n- Cliente: `carlos@cliente.cl`\n\n**Flujo sugerido:** Login → Películas/Boletos → Flujo de compra → Pagos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Autenticación",
      "item": [
        {
          "name": "Login - Administrador",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/api/v1/auth/login",
            "description": "Guarda el JWT en la variable de colección `jwt_token`.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"ana@administrador.cl\",\n  \"password\": \"TicketCine@2026\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.token);",
                  "  pm.collectionVariables.set('usuario_correo', json.correo);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Organizador",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"beatriz@organizador.cl\",\n  \"password\": \"TicketCine@2026\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.token);",
                  "  pm.collectionVariables.set('usuario_correo', json.correo);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Cliente (Carlos)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/api/v1/auth/login",
            "description": "Usar antes del flujo de carrito/compra.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"carlos@cliente.cl\",\n  \"password\": \"TicketCine@2026\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.token);",
                  "  pm.collectionVariables.set('usuario_correo', json.correo);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Nuevo cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Test\",\n  \"apellido\": \"Postman\",\n  \"correo\": \"test.postman@cliente.cl\",\n  \"password\": \"TicketCine@2026\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login - Credenciales inválidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"noexiste@cliente.cl\",\n  \"password\": \"wrong\"\n}"
            }
          },
          "response": [],
